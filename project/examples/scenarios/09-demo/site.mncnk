chunk "Scenario09" {
  output "./dist";

  for item in data("a.json") {
    page "/items/{{item.slug }}.html" using "layout.tpl" {
      let title = item.title;
      content {
        <h1>{item.title}</h1>
        <p>{item.body}</p>
      };
    };
  };

  for item in data("b.json") {
    page "/items/{{item.slug }}.html" using "layout.tpl" {
      let title = item.title;
      content {
        <h1>{item.title}</h1>
        <p>{item.body}</p>
      };
    };
  };
};
