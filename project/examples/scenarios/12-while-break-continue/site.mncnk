chunk "Metadata" {
  output: "./dist";
  title: "This is title Metadata for Browser SEO";
  metaDescription: "This is my description Metadata for Browser SEO";
};

chunk "While" {
  let counter: int = 0;
  while(counter < 20) {
    page "/{{counter}}.html" {
      content {
        <p>MyHtml No:{counter}</p>
      };
    };
    counter = counter + 1;
  };
};
