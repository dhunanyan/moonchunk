{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["index.ts", "moonchunk.ts", ".antlr/**/*.ts"],
  "exclude": ["node_modules", "dist", "examples"]
}
