{
  "name": "moonchunk",
  "version": "1.0.0",
  "description": "MoonChunk DSL runtime for generating static HTML from .mncnk sources",
  "author": "dhunanyan",
  "homepage": "https://github.com/dhunanyan/moonchunk#readme",
  "bugs": {
    "url": "https://github.com/dhunanyan/moonchunk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhunanyan/moonchunk.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "dsl",
    "interpreter",
    "antlr",
    "moonchunk",
    "static-site-generator",
    "compiler",
    "parser"
  ],
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "sh scripts/build.sh",
    "compile:ts": "tsc -p tsconfig.json",
    "compile:antlr": "sh scripts/compile-antlr.sh",
    "check": "sh scripts/check.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "node playground/server.js",
    "prepare": "husky",
    "start": "bash ./scripts/start.sh",
    "start:debug": "bash ./scripts/start-debug.sh",
    "prebuild": "rm -rf dist",
    "postbuild": "rm -rf .antlr"
  },
  "engines": {
    "node": ">=18",
    "yarn": ">=1.22.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "prettier": "^2.8.8",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "antlr4ts": "0.5.0-alpha.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
